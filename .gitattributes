# Force LF for shell scripts and YAML — Docker on Linux must read these
*.sh        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
Dockerfile  text eol=lf

# Treat binary assets as binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.woff      binary
*.woff2     binary
